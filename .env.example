# Copy to .env and adjust for local development

# Postgres (warehouse)
POSTGRES_USER=conversion
POSTGRES_PASSWORD=changethis
POSTGRES_DB=conversion
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=ecommerce.events

# Redis (Feast online store)
REDIS_HOST=localhost
REDIS_PORT=6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# BentoML
BENTOML_PORT=3000

# Event replay
REPLAY_EVENTS_PER_SECOND=20

# Airflow (batch training orchestration)
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
